# ── Database (required) ────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# ── Site ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://fasmetri.vercel.app"

# ── Admin (required for /admin) ────────────────────────────────────
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"
# HMAC secret for the admin session cookie. REQUIRED in production —
# the app throws at runtime if unset when NODE_ENV=production (a public
# dev fallback is used only outside production). Generate: openssl rand -hex 32
ADMIN_SESSION_SECRET="change-me-to-a-long-random-string"

# ── Scraper / import ───────────────────────────────────────────────
SCRAPER_ENABLED="false"
SCRAPER_MAX_PRODUCTS_PER_SHOP="120"
SCRAPER_USER_AGENT="FasmetriPriceBot/0.1 (+hello@fasmetri.ge)"
CRON_SECRET="change-me"

# ── Analytics (all optional — site works fine if empty) ────────────
# NOTE: this is a Next.js app, so client vars use the NEXT_PUBLIC_ prefix
# (not VITE_). Leave blank to disable a provider.
NEXT_PUBLIC_GA_ID=""              # Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=""      # Meta (Facebook) Pixel ID
NEXT_PUBLIC_TIKTOK_PIXEL_ID=""    # TikTok Pixel ID

# First-party shop_click storage uses the existing DATABASE_URL (server-side,
# via /api/out → ClickEvent). No client-side Supabase keys are required.
