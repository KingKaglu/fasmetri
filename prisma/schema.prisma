generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OfferAvailability {
  IN_STOCK
  OUT_OF_STOCK
  UNKNOWN
}

enum ScrapeStatus {
  QUEUED
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
  SKIPPED
}

enum AlertStatus {
  ACTIVE
  TRIGGERED
  PAUSED
}

enum RawOfferStatus {
  IMPORTED
  NORMALIZED
  ATTACHED
  NEEDS_REVIEW
  EXCLUDED
  UNABLE_TO_FETCH
  PARSE_FAILED
  DUPLICATE_URL
  STORE_UNAVAILABLE
  BLOCKED_OR_UNABLE_TO_FETCH
}

enum ProductVerificationStatus {
  NOT_STARTED
  IN_PROGRESS
  VERIFIED_FULLY
  PARTIALLY_VERIFIED
  NEEDS_REVIEW
  FAILED
}

enum StoreVerificationStatus {
  EXACT_MATCH_FOUND
  NO_MATCH_FOUND
  POSSIBLE_MATCH_NEEDS_REVIEW
  DIFFERENT_VARIANT_REJECTED
  STORE_UNAVAILABLE
  SEARCH_FAILED
  BLOCKED_OR_REQUIRES_MANUAL_CHECK
}

enum MatchReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OfferVerificationStatus {
  UNVERIFIED
  CONFIRMED
  POSSIBLE_MATCH
  REJECTED
  NEEDS_REVIEW
  DIFFERENT_VARIANT
}

model Shop {
  id                  String                      @id @default(cuid())
  slug                String                      @unique
  name                String
  baseUrl             String
  logoUrl             String?
  enabled             Boolean                     @default(false)
  reliabilityLabel    String?
  needsConfiguration  Boolean                     @default(true)
  lastScrapedAt       DateTime?
  offers              ProductOffer[]
  rawOffers           RawOffer[]
  scrapeRuns          ScrapeRun[]
  storeVerifications  ProductStoreVerification[]
  offerEvidence       OfferVerificationEvidence[]
  possibleMatches     PossibleProductMatch[]
  safePossibleMatches PossibleMatch[]
  lastIngestedAt      DateTime?
  ingestionStatus     String                      @default("NOT_STARTED")
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
}

model Category {
  id             String          @id @default(cuid())
  slug           String          @unique
  nameKa         String
  nameEn         String?
  parentId       String?
  parent         Category?       @relation("CategoryTree", fields: [parentId], references: [id])
  children       Category[]      @relation("CategoryTree")
  products       Product[]       @relation("ProductCategory")
  manualProducts Product[]       @relation("ManualProductCategory")
  parentProducts ParentProduct[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Product {
  id                          String                     @id @default(cuid())
  slug                        String                     @unique
  name                        String
  normalizedName              String
  canonicalKey                String?
  productIdentity             Json?
  brand                       String?
  model                       String?
  imageUrl                    String?
  categoryId                  String?
  category                    Category?                  @relation("ProductCategory", fields: [categoryId], references: [id])
  manualCategoryId            String?
  manualCategory              Category?                  @relation("ManualProductCategory", fields: [manualCategoryId], references: [id])
  categoryLocked              Boolean                    @default(false)
  categoryConfidence          Int?
  categoryNeedsReview         Boolean                    @default(true)
  categorySuggestedSlug       String?
  categoryReason              String?
  categoryMatchedRules        Json?
  categorySourceSignals       Json?
  offers                      ProductOffer[]
  matchCandidates             OfferMatchCandidate[]
  alerts                      UserPriceAlert[]
  manualGroupKey              String?
  matchingLocked              Boolean                    @default(false)
  crossStoreCheckedAt         DateTime?
  checkedShopsCount           Int                        @default(0)
  totalEnabledShopsCount      Int                        @default(0)
  missingOfferDiscoveryStatus String                     @default("PENDING")
  popularityScore             Int                        @default(0)
  isPublic                    Boolean                    @default(true)
  needsReview                 Boolean                    @default(false)
  archivedAt                  DateTime?
  reviewedAt                  DateTime?
  rawOffers                   RawOffer[]
  verifications               ProductVerification[]
  storeVerifications          ProductStoreVerification[]
  possibleMatches             PossibleProductMatch[]
  canonicalProducts           CanonicalProduct[]
  createdAt                   DateTime                   @default(now())
  updatedAt                   DateTime                   @updatedAt

  @@index([normalizedName])
  @@index([canonicalKey])
  @@index([categoryNeedsReview, categoryConfidence])
  @@index([isPublic, archivedAt, needsReview])
}

model ParentProduct {
  id                 String           @id @default(cuid())
  brand              String?
  model              String?
  productLine        String?
  baseSpecsJson      Json?
  categoryId         String?
  category           Category?        @relation(fields: [categoryId], references: [id])
  canonicalParentKey String           @unique
  title              String
  slug               String           @unique
  primaryImage       String?
  isPublic           Boolean          @default(false)
  needsReview        Boolean          @default(true)
  variants           ProductVariant[]
  offers             ProductOffer[]
  rawOffers          RawOffer[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([categoryId, isPublic])
  @@index([brand, model])
  @@index([needsReview, updatedAt])
}

model ProductVariant {
  id                  String         @id @default(cuid())
  parentProductId     String
  parentProduct       ParentProduct  @relation(fields: [parentProductId], references: [id], onDelete: Cascade)
  variantTitle        String
  canonicalVariantKey String         @unique
  color               String?
  storage             String?
  ram                 String?
  cpu                 String?
  gpu                 String?
  size                String?
  capacity            String?
  sku                 String?
  specsJson           Json?
  primaryImage        String?
  isPublic            Boolean        @default(false)
  needsReview         Boolean        @default(true)
  offers              ProductOffer[]
  rawOffers           RawOffer[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([parentProductId])
  @@index([isPublic, needsReview])
  @@index([canonicalVariantKey])
}

model ProductOffer {
  id                    String                      @id @default(cuid())
  productId             String
  product               Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  parentProductId       String?
  parentProduct         ParentProduct?              @relation(fields: [parentProductId], references: [id], onDelete: SetNull)
  variantId             String?
  variant               ProductVariant?             @relation(fields: [variantId], references: [id], onDelete: SetNull)
  shopId                String
  shop                  Shop                        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  rawOfferId            String?                     @unique
  rawOffer              RawOffer?                   @relation(fields: [rawOfferId], references: [id], onDelete: SetNull)
  externalId            String?
  url                   String
  affiliateUrl          String?
  title                 String
  canonicalKey          String?
  productIdentity       Json?
  matchStatus           String                      @default("UNVERIFIED")
  matchConfidence       Int?
  verificationStatus    OfferVerificationStatus     @default(CONFIRMED)
  extractedIdentityJson Json?
  lastCheckedAt         DateTime?
  currentPrice          Decimal                     @db.Decimal(12, 2)
  previousSeenPrice     Decimal?                    @db.Decimal(12, 2)
  oldPrice              Decimal?                    @db.Decimal(12, 2)
  currency              String                      @default("GEL")
  discountAmount        Decimal?                    @db.Decimal(12, 2)
  discountPercent       Int                         @default(0)
  isOnSale              Boolean                     @default(false)
  saleDetectedAt        DateTime?
  availability          OfferAvailability           @default(UNKNOWN)
  imageUrl              String?
  firstSeenAt           DateTime                    @default(now())
  lastSeenAt            DateTime                    @default(now())
  lastPriceChangedAt    DateTime?
  isActive              Boolean                     @default(true)
  missedSyncCount       Int                         @default(0)
  possiblyInactiveAt    DateTime?
  inactiveAt            DateTime?
  histories             PriceHistory[]
  clickEvents           ClickEvent[]
  matchCandidates       OfferMatchCandidate[]
  verificationEvidence  OfferVerificationEvidence[]
  storeVerifications    ProductStoreVerification[]
  possibleMatches       PossibleProductMatch[]
  canonicalProductId    String?
  canonicalProduct      CanonicalProduct?           @relation(fields: [canonicalProductId], references: [id], onDelete: SetNull)
  confidence            Int?
  reason                String?
  matcherVersion        String?
  matchedAt             DateTime?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  @@unique([shopId, url])
  @@unique([shopId, externalId])
  @@index([productId, currentPrice])
  @@index([parentProductId])
  @@index([variantId, currentPrice])
  @@index([canonicalKey])
  @@index([matchStatus, matchConfidence])
  @@index([canonicalProductId])
  @@index([matcherVersion, matchedAt])
  @@index([isActive, lastSeenAt])
  @@index([missedSyncCount])
}

model RawOffer {
  id                  String                 @id @default(cuid())
  shopId              String
  shop                Shop                   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  productId           String?
  product             Product?               @relation(fields: [productId], references: [id], onDelete: SetNull)
  parentProductId     String?
  parentProduct       ParentProduct?         @relation(fields: [parentProductId], references: [id], onDelete: SetNull)
  variantId           String?
  variant             ProductVariant?        @relation(fields: [variantId], references: [id], onDelete: SetNull)
  productOffer        ProductOffer?
  possibleMatches     PossibleProductMatch[]
  safePossibleMatches PossibleMatch[]
  externalId          String?
  originalTitle       String
  originalUrl         String
  originalImageUrl    String?
  rawPrice            Decimal?               @db.Decimal(12, 2)
  rawOldPrice         Decimal?               @db.Decimal(12, 2)
  currency            String                 @default("GEL")
  availability        OfferAvailability      @default(UNKNOWN)
  rawCategory         String?
  sourceCategory      String?
  breadcrumbs         Json?
  sourceBreadcrumbs   Json?
  description         String?
  imageAlt            String?
  rawDiscount         Int?
  rawSpecsJson        Json?
  importBatchId       String?
  storeKey            String?
  brand               String?
  model               String?
  normalizedTitle     String?
  cleanTitle          String?
  canonicalKey        String?
  productIdentity     Json?
  categorySlug        String?
  categoryConfidence  Int?
  categoryNeedsReview Boolean                @default(true)
  status              RawOfferStatus         @default(IMPORTED)
  unableToFetchReason String?
  errorMessage        String?
  scrapedAt           DateTime               @default(now())
  processedAt         DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@unique([shopId, originalUrl])
  @@unique([shopId, externalId])
  @@index([shopId, status, scrapedAt])
  @@index([canonicalKey])
  @@index([categorySlug, categoryNeedsReview])
  @@index([parentProductId])
  @@index([variantId])
  @@index([importBatchId])
  @@index([storeKey])
}

model CanonicalProduct {
  id              String          @id @default(cuid())
  categorySlug    String
  brand           String
  familyKey       String
  canonicalKey    String          @unique
  title           String
  normalizedTitle String
  primaryImage    String?
  specsJson       Json
  productId       String?         @unique
  product         Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  matcherVersion  String
  firstMatchedAt  DateTime        @default(now())
  lastMatchedAt   DateTime?
  offers          ProductOffer[]
  possibleMatches PossibleMatch[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([categorySlug, brand])
  @@index([familyKey])
  @@index([updatedAt])
  @@map("canonical_products")
}

model OfferMatchCandidate {
  id         String       @id @default(cuid())
  productId  String
  product    Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  offerId    String
  offer      ProductOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  confidence Int
  status     String       @default("POSSIBLE")
  reasons    Json?
  attributes Json?
  rejectedAt DateTime?
  reviewedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([productId, offerId])
  @@index([status, confidence])
}

model PossibleProductMatch {
  id               String            @id @default(cuid())
  productId        String
  product          Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  rawOfferId       String?
  rawOffer         RawOffer?         @relation(fields: [rawOfferId], references: [id], onDelete: Cascade)
  candidateOfferId String?
  candidateOffer   ProductOffer?     @relation(fields: [candidateOfferId], references: [id], onDelete: Cascade)
  shopId           String
  shop             Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  candidateTitle   String
  candidateUrl     String
  confidence       Int
  reason           String?
  status           MatchReviewStatus @default(PENDING)
  createdAt        DateTime          @default(now())
  reviewedAt       DateTime?

  @@index([status, confidence])
  @@index([productId, shopId])
}

model PossibleMatch {
  id                 String            @id @default(cuid())
  rawOfferId         String
  rawOffer           RawOffer          @relation(fields: [rawOfferId], references: [id], onDelete: Cascade)
  canonicalProductId String
  canonicalProduct   CanonicalProduct  @relation(fields: [canonicalProductId], references: [id], onDelete: Cascade)
  shopId             String
  shop               Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  confidence         Int
  reason             String
  matcherVersion     String
  rawTitle           String
  candidateTitle     String
  evidence           Json?
  status             MatchReviewStatus @default(PENDING)
  matchedAt          DateTime          @default(now())
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([rawOfferId, canonicalProductId, matcherVersion])
  @@index([status, confidence])
  @@index([rawOfferId])
  @@index([canonicalProductId])
  @@map("possible_matches")
}

model ProductVerification {
  id                      String                    @id @default(cuid())
  productId               String
  product                 Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)
  status                  ProductVerificationStatus @default(NOT_STARTED)
  startedAt               DateTime?
  finishedAt              DateTime?
  checkedShopsCount       Int                       @default(0)
  totalEnabledShopsCount  Int                       @default(0)
  exactMatchesFound       Int                       @default(0)
  possibleMatchesFound    Int                       @default(0)
  rejectedCandidatesCount Int                       @default(0)
  errorMessage            String?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt

  @@index([productId, status])
  @@index([status, updatedAt])
}

model ProductStoreVerification {
  id              String                  @id @default(cuid())
  productId       String
  product         Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  shopId          String
  shop            Shop                    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  status          StoreVerificationStatus
  checkedAt       DateTime                @default(now())
  matchedOfferId  String?
  matchedOffer    ProductOffer?           @relation(fields: [matchedOfferId], references: [id], onDelete: SetNull)
  candidateUrl    String?
  candidateTitle  String?
  candidatePrice  Decimal?                @db.Decimal(12, 2)
  candidateImage  String?
  matchConfidence Int?
  mismatchReasons Json?
  evidenceNotes   String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@unique([productId, shopId])
  @@index([shopId, status])
  @@index([status, checkedAt])
}

model OfferVerificationEvidence {
  id                    String       @id @default(cuid())
  productOfferId        String
  productOffer          ProductOffer @relation(fields: [productOfferId], references: [id], onDelete: Cascade)
  sourceShopId          String
  sourceShop            Shop         @relation(fields: [sourceShopId], references: [id], onDelete: Cascade)
  originalTitle         String
  originalUrl           String
  extractedIdentityJson Json?
  matchedFieldsJson     Json?
  missingFieldsJson     Json?
  mismatchFieldsJson    Json?
  confidence            Int
  verifiedAt            DateTime     @default(now())

  @@index([productOfferId, verifiedAt])
  @@index([sourceShopId, verifiedAt])
}

model ClickEvent {
  id          String        @id @default(cuid())
  offerId     String?
  offer       ProductOffer? @relation(fields: [offerId], references: [id], onDelete: SetNull)
  targetUrl   String
  // Denormalised snapshot at click time for first-party business reporting.
  productId   String?
  productName String?
  category    String?
  shopName    String?
  price       Decimal?      @db.Decimal(10, 2)
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  referrer    String?
  userAgent   String?
  createdAt   DateTime      @default(now())

  @@index([offerId, createdAt])
  @@index([shopName, createdAt])
  @@index([category, createdAt])
}

// Fraud guard for ClickEvent: one row per (ip, product, hour-bucket) hash.
// The unique constraint makes duplicate clicks a no-op; rows double as the
// rate-limit counter (count by ipHash in the last minute). Old rows are
// best-effort pruned by the click endpoint itself.
model ClickDedup {
  id        String   @id @default(cuid())
  dedupKey  String   @unique
  ipHash    String
  createdAt DateTime @default(now())

  @@index([ipHash, createdAt])
  @@index([createdAt])
}

// Brute-force guard for /api/admin/session: one row per FAILED login attempt.
// The POST handler counts rows by ipHash within a 15-minute window and 429s
// past the threshold; old rows are best-effort pruned by the login endpoint.
model LoginAttempt {
  id        String   @id @default(cuid())
  ipHash    String
  createdAt DateTime @default(now())

  @@index([ipHash, createdAt])
}

// Web Push subscriptions for price-alert notifications. Keyed to the same email
// a user enters when creating a UserPriceAlert; prepareTriggeredAlerts() pushes
// to every subscription matching that email when an alert fires.
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  email     String?
  createdAt DateTime @default(now())

  @@index([email])
}

model PriceHistory {
  id           String            @id @default(cuid())
  offerId      String
  offer        ProductOffer      @relation(fields: [offerId], references: [id], onDelete: Cascade)
  price        Decimal           @db.Decimal(12, 2)
  oldPrice     Decimal?          @db.Decimal(12, 2)
  availability OfferAvailability @default(UNKNOWN)
  capturedAt   DateTime          @default(now())

  @@index([offerId, capturedAt])
}

model ScrapeRun {
  id           String       @id @default(cuid())
  shopId       String?
  shop         Shop?        @relation(fields: [shopId], references: [id], onDelete: SetNull)
  status       ScrapeStatus @default(QUEUED)
  startedAt    DateTime     @default(now())
  finishedAt   DateTime?
  pagesVisited Int          @default(0)
  offersSeen   Int          @default(0)
  errorLog     Json?
  createdAt    DateTime     @default(now())
}

// One row per triggered price alert (written by src/server/alerts/evaluate.ts)
// so admins can see what fired even when no email provider is configured.
// Deliberately relation-free: alerts/products may be deleted later.
model AlertEvent {
  id          String   @id @default(cuid())
  alertId     String
  email       String
  productId   String?
  productName String
  targetPrice Decimal  @db.Decimal(12, 2)
  offerPrice  Decimal  @db.Decimal(12, 2)
  shopName    String?
  notifiedVia String   @default("none") // "none" | "console" | "resend" | "smtp"
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([alertId])
}

// Weekly catalog health snapshot (written by scripts/catalog-health.ts via
// catalog-audit.yml). detailsJson carries capped sample lists per check.
model CatalogHealthReport {
  id                   String   @id @default(cuid())
  orphanCanonicals     Int      @default(0)
  unlinkedOffers       Int      @default(0)
  staleOffers          Int      @default(0)
  duplicateTitleGroups Int      @default(0)
  detailsJson          Json?
  createdAt            DateTime @default(now())

  @@index([createdAt])
}

// Price moves outside sane bounds (new price < 10% or > 300% of the stored
// price) caught during store syncs. The sync keeps the old price instead of
// publishing the suspect one and records the move here for admin review.
model PriceAnomaly {
  id            String   @id @default(cuid())
  store         String // "zoommer" | "ee"
  category      String // "phones" | "laptops"
  offerUrl      String
  title         String
  previousPrice Decimal  @db.Decimal(12, 2)
  newPrice      Decimal  @db.Decimal(12, 2)
  ratio         Float
  resolved      Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([store, category])
  @@index([resolved])
}

model SyncLog {
  id            String   @id @default(cuid())
  store         String // "ee" | "zoommer"
  category      String // "phones" | "laptops"
  runType       String // "prices" | "full"
  status        String // "success" | "failure" | "partial"
  offersScraped Int      @default(0)
  offersUpdated Int      @default(0)
  errorMessage  String?
  startedAt     DateTime
  completedAt   DateTime
  createdAt     DateTime @default(now())

  @@index([store, category])
  @@index([createdAt])
}

model UserPriceAlert {
  id             String      @id @default(cuid())
  email          String
  productId      String
  product        Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  targetPrice    Decimal     @db.Decimal(12, 2)
  status         AlertStatus @default(ACTIVE)
  lastNotifiedAt DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([email, status])
}
